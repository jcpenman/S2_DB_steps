<CustomObject CBOHint="" CustomSQL="SELECT count(learner.learner_id)&quot;Account Usage&quot; &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 1&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 2&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 3&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 4&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 5&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 6&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 7&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 8&#x000d;&#x000a;" Description="Account Usage Query" DeveloperKey="ACCOUNT_USAGE_QUERY" DeveloperKeyFrozen="False" DistinctFlag="False" ExternalDatabaseLink="" ExternalObjectName="" ExternalObjectOwner="" Hidden="False" Id="100046" Name="Account Usage Query" NonDeterministic="False" SQL="( SELECT &quot;Account Usage&quot; AS i100094 FROM (SELECT count(learner.learner_id)&quot;Account Usage&quot; &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 1&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 2&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 3&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 4&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 5&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 6&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 7&#x000d;&#x000a;UNION ALL   &#x000d;&#x000a;SELECT count(learner.learner_id)&quot;Account Usage&quot;  &#x000d;&#x000a;    FROM learner, learner_application&#x000d;&#x000a;   WHERE learner.learner_id = learner_application.learner_id&#x000d;&#x000a;   GROUP by learner.learner_id&#x000d;&#x000a;    having count (learner_application_id) = 8&#x000d;&#x000a;) CUO100046 )" UserProperty1="" UserProperty2="">
