<CustomObject CBOHint="" CustomSQL="SELECT distinct a.learner_id, b.postcode, c.course_level_desc &quot;QUALIFICATION LEVEL&quot;,&#x000d;&#x000a;       a.fee_calculated &quot;FEE AWARDED&quot;, e.payment_desc &quot;FEE STATUS&quot;,&#x000d;&#x000a;       f.status &quot;APPLICATION STATUS&quot;, a.recover_fees&#x000d;&#x000a;  FROM learner_application a,&#x000d;&#x000a;       learner b,&#x000d;&#x000a;       course_level c,&#x000d;&#x000a;       learner_payment d,&#x000d;&#x000a;       payment_status e,&#x000d;&#x000a;       application_status f&#x000d;&#x000a; WHERE a.learner_id = b.learner_id&#x000d;&#x000a;   AND a.course_id = c.course_id&#x000d;&#x000a;   AND a.learner_application_id = d.learner_application_id&#x000d;&#x000a;   AND d.payment_status_id = e.payment_status_id&#x000d;&#x000a;   AND e.payment_desc = &apos;PAID&apos;&#x000d;&#x000a;   AND a.application_status_id = f.application_status_id&#x000d;&#x000a;   AND b.postcode IS NOT NULL&#x000d;&#x000a;" Description="Custom2" DeveloperKey="CUSTOM2" DeveloperKeyFrozen="False" DistinctFlag="False" ExternalDatabaseLink="" ExternalObjectName="" ExternalObjectOwner="" Hidden="False" Id="100051" Name="Custom2" NonDeterministic="False" SQL="( SELECT &quot;APPLICATION STATUS&quot; AS i100109, &quot;FEE AWARDED&quot; AS i100182, &quot;FEE STATUS&quot; AS i100190, LEARNER_ID AS i100255, POSTCODE AS i100304, &quot;QUALIFICATION LEVEL&quot; AS i100338, RECOVER_FEES AS i100339 FROM (SELECT distinct a.learner_id, b.postcode, c.course_level_desc &quot;QUALIFICATION LEVEL&quot;,&#x000d;&#x000a;       a.fee_calculated &quot;FEE AWARDED&quot;, e.payment_desc &quot;FEE STATUS&quot;,&#x000d;&#x000a;       f.status &quot;APPLICATION STATUS&quot;, a.recover_fees&#x000d;&#x000a;  FROM learner_application a,&#x000d;&#x000a;       learner b,&#x000d;&#x000a;       course_level c,&#x000d;&#x000a;       learner_payment d,&#x000d;&#x000a;       payment_status e,&#x000d;&#x000a;       application_status f&#x000d;&#x000a; WHERE a.learner_id = b.learner_id&#x000d;&#x000a;   AND a.course_id = c.course_id&#x000d;&#x000a;   AND a.learner_application_id = d.learner_application_id&#x000d;&#x000a;   AND d.payment_status_id = e.payment_status_id&#x000d;&#x000a;   AND e.payment_desc = &apos;PAID&apos;&#x000d;&#x000a;   AND a.application_status_id = f.application_status_id&#x000d;&#x000a;   AND b.postcode IS NOT NULL&#x000d;&#x000a;) CUO100051 )" UserProperty1="" UserProperty2="">
