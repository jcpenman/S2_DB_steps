<CustomObject CBOHint="" CustomSQL="SELECT la.learner_application_id, p.provider_id, p.provider_name, p.prov_type_id, la.course_id,&#x000d;&#x000a;       c.course_level_desc, la.session_year, la.date_app_recd,&#x000d;&#x000a;       la.payment_date, la.fee_requested, la.fee_calculated,&#x000d;&#x000a;       la.fee_requested - la.fee_calculated &quot;LEARNER_CONTRIBUTIONS&quot;,&#x000d;&#x000a;       la.help_amount&#x000d;&#x000a;  FROM learner_application la, provider p, course_level c&#x000d;&#x000a; WHERE la.provider_id = p.provider_id&#x000d;&#x000a;   AND la.course_id = c.course_id&#x000d;&#x000a;   AND la.course_id IS NOT NULL&#x000d;&#x000a;   AND p.prov_type_id IN (1, 2, 3)&#x000d;&#x000a;" Description="Custom Table 6" DeveloperKey="CUSTOM_TABLE_6" DeveloperKeyFrozen="False" DistinctFlag="False" ExternalDatabaseLink="" ExternalObjectName="" ExternalObjectOwner="" Hidden="False" Id="102060" Name="Custom Table 6" NonDeterministic="False" SQL="( SELECT LEARNER_APPLICATION_ID AS i102063, PROVIDER_ID AS i102064, PROV_TYPE_ID AS i102065, COURSE_ID AS i102066, COURSE_LEVEL_DESC AS i102067, SESSION_YEAR AS i102068, DATE_APP_RECD AS i102069, PAYMENT_DATE AS i102070, FEE_REQUESTED AS i102071, FEE_CALCULATED AS i102072, LEARNER_CONTRIBUTIONS AS i102073, HELP_AMOUNT AS i102074, PROVIDER_NAME AS i102140 FROM (SELECT la.learner_application_id, p.provider_id, p.provider_name, p.prov_type_id, la.course_id,&#x000d;&#x000a;       c.course_level_desc, la.session_year, la.date_app_recd,&#x000d;&#x000a;       la.payment_date, la.fee_requested, la.fee_calculated,&#x000d;&#x000a;       la.fee_requested - la.fee_calculated &quot;LEARNER_CONTRIBUTIONS&quot;,&#x000d;&#x000a;       la.help_amount&#x000d;&#x000a;  FROM learner_application la, provider p, course_level c&#x000d;&#x000a; WHERE la.provider_id = p.provider_id&#x000d;&#x000a;   AND la.course_id = c.course_id&#x000d;&#x000a;   AND la.course_id IS NOT NULL&#x000d;&#x000a;   AND p.prov_type_id IN (1, 2, 3)&#x000d;&#x000a;) CUO102