<CustomObject CBOHint="" CustomSQL="select distinct a.primary_key as ID, a.username, trunc(a.aud_date), b.forename, b.surname, c.session_year&#x000d;&#x000a;from learner_aud a, learner b, learner_application c&#x000d;&#x000a;where a.primary_key = b.learner_id&#x000d;&#x000a;and a.primary_key = c.learner_id(+)&#x000d;&#x000a;UNION &#x000d;&#x000a;select distinct d.primary_key as ID, d.username, trunc(d.aud_date), f.forename, f.surname, e.session_year  &#x000d;&#x000a;from learner_application_aud d, learner_application e, learner f&#x000d;&#x000a;where d.primary_key = e.learner_application_id&#x000d;&#x000a;and e.learner_id = f.learner_id(+)&#x000d;&#x000a;" Description="Custom Query to return learner and learner apps worked on" DeveloperKey="CUSTOM11" DeveloperKeyFrozen="False" DistinctFlag="False" ExternalDatabaseLink="" ExternalObjectName="" ExternalObjectOwner="" Hidden="False" Id="100049" Name="Work Carried Out Query" NonDeterministic="False" SQL="( SELECT FORENAME AS i100202, ID AS i100215, SESSION_YEAR AS i100344, SURNAME AS i100354, &quot;TRUNC(A.AUD_DATE)&quot; AS i100369, USERNAME AS i100371 FROM (select distinct a.primary_key as ID, a.username, trunc(a.aud_date), b.forename, b.surname, c.session_year&#x000d;&#x000a;from learner_aud a, learner b, learner_application c&#x000d;&#x000a;where a.primary_key = b.learner_id&#x000d;&#x000a;and a.primary_key = c.learner_id(+)&#x000d;&#x000a;UNION &#x000d;&#x000a;select distinct d.primary_key as ID, d.username, trunc(d.aud_date), f.forename, f.surname, e.session_year  &#x000d;&#x000a;from learner_application_aud d, learner_application e, learner f&#x000d;&#x000a;where d.primary_key = e.learner_application_id&#x000d;&#x000a;and e.learner_id = f.learner_id(+)&#x000d;&#x000a;) CUO100049 )" UserProperty1="" UserProperty2="">
