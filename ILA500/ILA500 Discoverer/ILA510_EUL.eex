<CustomObject CBOHint="" CustomSQL="select distinct a.learner_id as ID, a.forename, a.surname, c.session_year, b.column_name, b.old, b.new, trunc(b.aud_date), b.action, b.username&#x000d;&#x000a;from learner a, learner_aud b, learner_application c, learner_application_aud d&#x000d;&#x000a;where a.learner_id = b.primary_key&#x000d;&#x000a;and a.learner_id = c.learner_id&#x000d;&#x000a;and c.learner_application_id = d.primary_key&#x000d;&#x000a;union&#x000d;&#x000a;select distinct a.learner_id as ID, a.forename, a.surname, c.session_year, d.column_name, d.old, d.new, trunc(d.aud_date), d.action, d.username&#x000d;&#x000a;from learner a, learner_aud b, learner_application c, learner_application_aud d&#x000d;&#x000a;where a.learner_id = b.primary_key&#x000d;&#x000a;and a.learner_id = c.learner_id&#x000d;&#x000a;and c.learner_application_id = d.primary_key&#x000d;&#x000a;" Description="Work Carried Out Query 10" DeveloperKey="WORK_CARRIED_OUT_QUERY_10" DeveloperKeyFrozen="False" DistinctFlag="False" ExternalDatabaseLink="" ExternalObjectName="" ExternalObjectOwner="" Hidden="False" Id="100055" Name="Work Carried Out Query 10" NonDeterministic="False" SQL="( SELECT ACTION AS i100095, COLUMN_NAME AS i100137, FORENAME AS i100203, ID AS i100216, NEW AS i100279, OLD AS i100289, SESSION_YEAR AS i100345, SURNAME AS i100355, &quot;TRUNC(B.AUD_DATE)&quot; AS i100370, USERNAME AS i100372 FROM (select distinct a.learner_id as ID, a.forename, a.surname, c.session_year, b.column_name, b.old, b.new, trunc(b.aud_date), b.action, b.username&#x000d;&#x000a;from learner a, learner_aud b, learner_application c, learner_application_aud d&#x000d;&#x000a;where a.learner_id = b.primary_key&#x000d;&#x000a;and a.learner_id = c.learner_id&#x000d;&#x000a;and c.learner_application_id = d.primary_key&#x000d;&#x000a;union&#x000d;&#x000a;select distinct a.learner_id as ID, a.forename, a.surname, c.session_year, d.column_name, d.old, d.new, trunc(d.aud_date), d.action, d.username&#x000d;&#x000a;from le